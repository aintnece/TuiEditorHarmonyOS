{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(docker *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'CC edited files — Hermes will review'"
          }
        ]
      }
    ]
  }
}
